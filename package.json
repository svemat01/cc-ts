{
    "name": "@cc-ts/root",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "build": "bun run --workspaces --if-present build",
        "test": "bun run --workspaces --if-present test",
        "publish": "bun run build && for dir in packages/*; do (cd \"$dir\" && bun publish || true); done && changeset tag",
        "docs": "bun run --filter '@cc-ts/helpers' build && bun run buildDocs.ts"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typedoc": "^0.27.1",
        "typedoc-material-theme": "^1.2.0"
    },
    "peerDependencies": {
        "typescript": "^5.7.2"
    },
    "workspaces": [
        "examples/*",
        "packages/*",
        "libraries/*"
    ],
    "dependencies": {
        "@changesets/cli": "^2.27.10"
    }
}
