{
    "name": "@cc-ts/builder",
    "main": "src/index.ts",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "type": "module",
    "version": "0.3.0",
    "private": false,
    "exports": {
        ".": "./src/index.ts",
        "./cli": "./src/cc-ts.ts",
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "README.md",
        "CHANGELOG.md",
        "TESTING.md",
        "tsconfig-schema.json"
    ],
    "bin": {
        "cc-ts": "src/cc-ts.ts"
    },
    "scripts": {
        "build": "bun x tsc --noEmit",
        "test": "bun test --preload ./test/setup.ts",
        "test:update-snapshots": "bun test --preload ./test/setup.ts --update-snapshots",
        "typecheck": "bun x tsc --noEmit"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/yargs": "^17.0.32"
    },
    "peerDependencies": {
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "@jackmacwindows/typescript-to-lua": "^1.32.0",
        "@lvksh/logger": "^1.6.4",
        "enhanced-resolve": "^5.17.1",
        "kleur": "^4.1.5",
        "luamin": "^1.0.4",
        "pino": "^9.5.0",
        "pino-pretty": "^13.0.0",
        "source-map": "^0.7.4",
        "yargs": "^17.7.2"
    },
    "publishConfig": {
        "access": "public"
    }
}
