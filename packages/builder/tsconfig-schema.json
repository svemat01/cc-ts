{
    "title": "tsconfig.json with TSTL & CC-TS options",
    "description": "JSON schema for the TypeScript compiler's configuration file with TSTL & CC-TS options",
    "$schema": "http://json-schema.org/draft-07/schema",
    "allOf": [
        {
            "$ref": "https://raw.githubusercontent.com/svemat01/cc-ts-tstl/refs/heads/master/tsconfig-schema.json"
        }
    ],
    "properties": {
        "cc-ts": {
            "description": "CC-TS compiler options.",
            "type": "object",
            "definitions": {
                "//": {
                    "reference": "https://typescripttolua.github.io/docs/configuration#custom-options"
                }
            },
            "properties": {
                "builtInModules": {
                    "description": "A list of built-in modules to include in the bundle.",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "minify": {
                    "description": "Minify the resulting Lua files.",
                    "type": "boolean",
                    "default": false
                },
                "analyze": {
                    "description": "Print a dependency analysis report after a build.",
                    "type": "boolean",
                    "default": false
                },
                "analyzeFormat": {
                    "description": "Format for dependency analysis output.",
                    "type": "string",
                    "enum": ["text", "json"],
                    "default": "text"
                },
                "analyzeOutput": {
                    "description": "Write dependency analysis output to a file.",
                    "type": "string"
                },
                "serve": {
                    "description": "Serve the bundle over HTTP.",
                    "type": "boolean",
                    "default": false
                },
                "servePort": {
                    "description": "The port to serve the bundle on.",
                    "type": "number",
                    "default": 8080
                },
                "debug": {
                    "description": "Enable debug mode.",
                    "type": "boolean",
                    "default": false
                },
                "extraPaths": {
                    "description": "A list of extra paths to include in the bundle.",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "explain": {
                    "description": "Specific modules to explain in the analysis output.",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "externals": {
                    "description": "Rules for marking dependencies as built-in, runtime-external, or copied into the output directory.",
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["pattern"],
                        "properties": {
                            "pattern": {
                                "type": "string"
                            },
                            "mode": {
                                "type": "string",
                                "enum": ["builtin", "external", "copy"]
                            },
                            "outDir": {
                                "type": "string"
                            },
                            "reason": {
                                "type": "string"
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "ignoreAsEntryPoint": {
                    "description": "A list of files to ignore as entry points.",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "reproducible": {
                    "description": "Remove volatile metadata such as build timestamps from bundle headers.",
                    "type": "boolean",
                    "default": false
                }
            },
            "dependencies": {}
        }
    },
    "allowTrailingCommas": true
}
